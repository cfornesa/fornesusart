# .env.example — copy to .env and fill in values.
# Never commit .env to version control.
# See DECISIONS.md → Environment Variables Required for the full list.

# Required MySQL configurations:
DB_HOST=localhost
DB_NAME=fornesusart
DB_USER=
DB_PASS=

# For Google and GitHub OAuth, it's recommended to create two applications for each platform (local and production) to test and deploy effectively.
    # In your development and production environments, simply use different sets of variables OR duplicate each set of variables and comment out the irrelevant set per environment.

# For GitHub OAuth, you need to create an OAuth App in your GitHub account settings and get the Client ID and Client Secret.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
ADMIN_GITHUB_USERNAMES=

# For Google OAuth, you need to set up a project in the Google Cloud Console and create OAuth 2.0 credentials.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ADMIN_GOOGLE_EMAILS=
